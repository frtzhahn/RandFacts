<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns:fx="http://javafx.com/fxml" alignment="TOP_CENTER" spacing="30.0" style="-fx-background-color: transparent; -fx-padding: 40px;">
    
    <Label text="SAVED FACTS" styleClass="title"/>
    
    <VBox spacing="15.0" style="-fx-background-color: rgba(60,60,60,0.8); -fx-background-radius: 20px; -fx-padding: 30px; -fx-max-width: 900px; -fx-min-width: 900px;">
        <Label text="YOUR KNOWLEDGE ARCHIVE" styleClass="subtitle" style="-fx-font-size: 12px;"/>
        
        <VBox spacing="10.0">
            <!-- Fact 1 -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: rgba(255,100,100,0.1); -fx-padding: 20px; -fx-background-radius: 10px; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10px;">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="The Eiffel Tower can be 15 cm taller during the summer due to thermal expansion." styleClass="fact-text"/>
                </VBox>
                <Label text="DELETE" style="-fx-text-fill: #ff5555; -fx-font-size: 10px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
            
            <!-- Fact 2 -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: rgba(100,255,100,0.05); -fx-padding: 20px; -fx-background-radius: 10px; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10px;">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="A single strand of spider silk is thinner than a human hair but stronger than steel." styleClass="fact-text"/>
                </VBox>
                <Label text="DELETE" style="-fx-text-fill: #ff5555; -fx-font-size: 10px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
            
            <!-- Empty state placeholder or more items can go here -->
        </VBox>
    </VBox>

</VBox>
