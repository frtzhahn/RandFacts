<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>
<?import java.net.URL?>
<?import javafx.scene.media.MediaView?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.randfacts.MainController">

	<!-- background looping video -->
	<MediaView fx:id="backgroundMediaView" fitHeight="1080.0" fitWidth="1920.0" />

	<stylesheets>
		<URL value="@main.css" />
	</stylesheets>

	<!-- <ImageView fitHeight="1080.0" fitWidth="1920.0" pickOnBounds="true"> -->
	<!-- 	<image> -->
	<!-- 		<Image url="@images/background-loop.gif" /> -->
	<!-- 	</image> -->
	<!-- </ImageView> -->


	<HBox AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 20px 20px 0px 0px;" onMousePressed="#onMousePressed" onMouseDragged="#onMouseDragged">
		<Button text="—" onAction="#minimizeWindow" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-font-weight: bold;"/>
		<Button text="☐" onAction="#maximizeWindow" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-font-weight: bold;"/>
		<Button text="X" onAction="#closeWindow" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-font-weight: bold;"/>
	</HBox>

	<StackPane fx:id="contentArea" 
			   AnchorPane.topAnchor="80.0" 
			   AnchorPane.bottomAnchor="120.0" 
			   AnchorPane.leftAnchor="0.0" 
			   AnchorPane.rightAnchor="0.0">
		<!-- Content will be loaded here -->
	</StackPane>

	<HBox prefHeight="80.0"
		AnchorPane.bottomAnchor="20.0"
		AnchorPane.leftAnchor="0.0"
		AnchorPane.rightAnchor="0.0"
		alignment="CENTER"
		spacing="40.0">

		<Label fx:id="navHomepage" text="HOMEPAGE" styleClass="nav-item" onMouseClicked="#goToHomepage" />
		<Label fx:id="navSavedFacts" text="SAVED FACTS" styleClass="nav-item" onMouseClicked="#goToSavedFacts" />
		<Label fx:id="navHistory" text="HISTORY" styleClass="nav-item" onMouseClicked="#goToHistory" />
		<Label fx:id="navDashboard" text="DASHBOARD" styleClass="nav-item" onMouseClicked="#goToDashboard" />
		<Label fx:id="navAboutUs" text="ABOUT US" styleClass="nav-item" onMouseClicked="#goToAboutUs" />

	</HBox>

</AnchorPane>
