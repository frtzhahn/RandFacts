<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns:fx="http://javafx.com/fxml" alignment="CENTER" spacing="20.0" style="-fx-background-color: transparent;">
    <Label text="RANDOM FACTS" styleClass="title" style="-fx-font-size: 40px;"/>
    <Label text="Industrial Grade Knowledge Engine" styleClass="subtitle"/>
    
    <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 20px; -fx-padding: 40px; -fx-max-width: 600px;">
        <Label text="Click 'REVEAL' to discover something new." styleClass="fact-text"/>
        <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20px 0 0 0;">
            <Label text="REVEAL" style="-fx-background-color: white; -fx-text-fill: black; -fx-padding: 10px 40px; -fx-background-radius: 5px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</VBox>
