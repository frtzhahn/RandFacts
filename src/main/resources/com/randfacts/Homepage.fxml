<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Region?>

<VBox xmlns:fx="http://javafx.com/fxml"
	alignment="CENTER"
	spacing="30.0"
	style="-fx-background-color: transparent;"
	fx:controller="com.randfacts.HomepageController">

	<Label text="How should we start today?"
		styleClass="title" />

	<!-- controls section -->
	<!-- <HBox alignment="CENTER" spacing="20.0"> -->
	<!-- 	<ComboBox fx:id="categoryComboBox" promptText="Select Category" prefWidth="250.0" /> -->
	<!-- 	<Button fx:id="generateButton" text="	GENERATE" styleClass="pill-btn" onAction="#handleGenerate" /> -->
	<!-- </HBox> -->

	<StackPane prefHeight="600.0"
		prefWidth="900.0"
		maxWidth="1100.0"
		styleClass="glass-card">

		<VBox spacing="20.0" style="-fx-padding: 30;">
			<Label fx:id="titleLabel" 
				text="lorem ipsum"
				styleClass="subtitle" wrapText="true" />

			<Region prefHeight="1" style="-fx-background-color: rgba(225,225,225,0.15);" />

			<ScrollPane fx:id="factScrollPane"
				hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
				fitToWidth="true"
				style="-fx-background-color: transparent; -fx-background: transparent;"
				prefHeight="400.0">

			<Label fx:id="factLabel"	
				text="daily dose of random ahh"
				styleClass="homepage-content"
				wrapText="true" />

	</ScrollPane>
</VBox>

<AnchorPane pickOnBounds="false">

				<Button fx:id="saveButton"
					text="✔"
					styleClass="circle-btn"
					AnchorPane.bottomAnchor="20.0"
					AnchorPane.leftAnchor="20.0"
					onAction="#handleSave" />

				<HBox spacing="15.0"
					AnchorPane.bottomAnchor="20.0"
					AnchorPane.rightAnchor="20.0"
					alignment="CENTER">

				<Button fx:id="generateButton" 
					text="GENERATE" 
					styleClass="pill-btn" 
					onAction="#handleGenerate" />

				<ComboBox fx:id="categoryComboBox" 
					promptText="Select Category" 
					prefWidth="200.0" />

			</HBox>
		</AnchorPane>
	</StackPane>
</VBox>
