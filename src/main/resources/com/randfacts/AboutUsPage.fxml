<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.Region?>

<VBox xmlns:fx="http://javafx.com/fxml" 
	fx:controller="com.randfacts.AboutUsController"
	alignment="TOP_CENTER" 
	spacing="30.0" 
	style="-fx-background-color: transparent; -fx-padding: 40px 0 0 0;">
    
    <Label text="ABOUT US" styleClass="title"/>
    
    <!-- Project Repository Card -->
		<VBox alignment="CENTER" 
			spacing="30.0" 
			styleClass="glass-card-aboutus">

        <Label text="PROJECT REPOSITORY ON GITHUB" styleClass="subtitle" />
        <Region prefHeight="1" style="-fx-background-color: #555; -fx-scale-x: 0.8;"/>
        
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 20px 0 0 50px;">
            <VBox style="-fx-background-color: transparent; -fx-background-radius: 15px; -fx-padding: 10px;">
                 <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@images/github.png" /> 
                    </image>
                 </ImageView>
							 </VBox>
							 <!-- added clickable url feature -->
			<Hyperlink text="https://github.com/frtzhahn/RandFacts" 
                       onAction="#handleLinkClick" 
                       styleClass="stat-value" 
                       style="-fx-underline: false; -fx-border-color: transparent;"/>
        </HBox>
    </VBox>
    
    <!-- Contributors Card -->
		<VBox alignment="CENTER" 
			spacing="10.0" 
			styleClass="glass-card-aboutus">

        <Label text="PROJECT PROJECT CONTRIBUTORS" styleClass="subtitle" />
        <Region prefHeight="1" style="-fx-background-color: #555; -fx-scale-x: 0.8;"/>
        
        <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 10px 0 0 0;">
            <!-- Contributor 1 -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 0 0 0 50px;">
                <VBox style="-fx-background-color: transparent; -fx-background-radius: 10px; -fx-padding: 6px;">
                     <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@images/github.png" />
                        </image>
                     </ImageView>
                </VBox>
							 <!-- added clickable url feature -->
                <Hyperlink text="https://github.com/frtzhahn" 
                           onAction="#handleLinkClick" 
                           styleClass="stat-value" 
                           style="-fx-underline: false; -fx-border-color: transparent;"/>
            </HBox>
            
            <!-- Contributor 2 -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 0 0 0 50px;">
                <VBox style="-fx-background-color: transparent; -fx-background-radius: 10px; -fx-padding: 6px;">
                     <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@images/github.png" />
                        </image>
                     </ImageView>
                </VBox>
							 <!-- added clickable url feature -->
                <Hyperlink text="https://github.com/gabunijames31-boop" 
                           onAction="#handleLinkClick" 
                           styleClass="stat-value" 
                           style="-fx-underline: false; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>
